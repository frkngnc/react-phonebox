{
  "name": "react-phonebox",
  "version": "2.1.0",
  "author": "Furkan Genc",
  "description": "A customizable phone input component with built-in multi-language support.",
  "license": "MIT",
  "keywords": [
    "phone",
    "phone input",
    "react phone input",
    "intl phone input",
    "phonebox",
    "react phonebox",
    "i18n react phone",
    "country selector",
    "react",
    "phone number validation",
    "react libphonenumber",
    "libphonenumber"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/frkngnc/react-phonebox.git"
  },
  "bugs": {
    "url": "https://github.com/frkngnc/react-phonebox/issues"
  },
  "homepage": "https://frkngnc.github.io/react-phonebox",
  "main": "dist/index.cjs",
  "module": "dist/index.es.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.mjs",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "npm --prefix docs start",
    "docs:build": "npm --prefix docs run build",
    "build": "vite build && tsc --emitDeclarationOnly",
    "test": "vitest run",
    "prepublishOnly": "npm test && npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "libphonenumber-js": "^1.12.9"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^22.1.0",
    "typescript": "^5.0.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
